def read_text(path: Path) -> str | None:
    try:
        return path.read_text(errors="replace").strip()
    except OSError:
        return None


def read_int(path: Path) -> int | None:
    value = read_text(path)
    if value is None:
        return None
    try:
        return int(value)
    except ValueError:
        return None


def clamp(value: float, low: float, high: float) -> float:
    return max(low, min(high, value))


def format_bytes(value: int | float | None) -> str:
    if value is None:
        return "n/a"
    size = float(value)
    units = ["B", "KiB", "MiB", "GiB", "TiB"]
    unit = units[0]
    for unit in units:
        if abs(size) < 1024.0 or unit == units[-1]:
            break
        size /= 1024.0
    return f"{size:.1f} {unit}"


def bar(percent: int | float | None, width: int = 24) -> str:
    if percent is None:
        return "[" + "?" * max(0, width) + "]"
    pct = clamp(float(percent), 0.0, 100.0)
    filled = int(round((pct / 100.0) * width))
    return "[" + ("#" * filled) + ("-" * (width - filled)) + "]"


def meter_style(percent: int | float | None) -> str:
    if percent is None:
        return "muted"
    pct = clamp(float(percent), 0.0, 100.0)
    if pct >= 90.0:
        return "bad"
    if pct >= 75.0:
        return "warn"
    return "good"


def section(title: str, body: list[str], width: int) -> list[str]:
    header = f"+-- {title} "
    header += "-" * max(0, width - len(header))
    return [header, *body, ""]


def join_columns(left: list[str], right: list[str], left_width: int, gap: str = "   ") -> list[str]:
    rows: list[str] = []
    height = max(len(left), len(right))
    for index in range(height):
        left_text = left[index] if index < len(left) else ""
        right_text = right[index] if index < len(right) else ""
        rows.append(f"{left_text:<{left_width}}{gap}{right_text}")
    return rows


def active_clock(path: Path) -> str | None:
    value = read_text(path)
    if not value:
        return None
    for line in value.splitlines():
        if "*" in line:
            return line.strip()
    return value.splitlines()[0].strip() if value.splitlines() else None


def first_glob(root: Path, pattern: str) -> Path | None:
    matches = glob.glob(str(root / pattern))
    return Path(matches[0]) if matches else None


def collect_amd_gpus(drm_root: Path = DEFAULT_DRM_ROOT) -> list[dict[str, Any]]:
    gpus: list[dict[str, Any]] = []
    for device in sorted(drm_root.glob("card*/device")):
        if read_text(device / "vendor") != "0x1002":
            continue

        temp_path = first_glob(device, "hwmon/hwmon*/temp1_input")
        power_path = first_glob(device, "hwmon/hwmon*/power1_average")
        temp_raw = read_int(temp_path) if temp_path else None
        power_raw = read_int(power_path) if power_path else None

        gpus.append({
            "vendor": "AMD",
            "name": "Radeon",
            "path": str(device),
            "gpu_busy_percent": read_int(device / "gpu_busy_percent"),
            "mem_busy_percent": read_int(device / "mem_busy_percent"),
            "vram_used": read_int(device / "mem_info_vram_used"),
            "vram_total": read_int(device / "mem_info_vram_total"),
            "vis_vram_used": read_int(device / "mem_info_vis_vram_used"),
            "vis_vram_total": read_int(device / "mem_info_vis_vram_total"),
            "temp_c": temp_raw / 1000.0 if temp_raw is not None else None,
            "power_w": power_raw / 1000000.0 if power_raw is not None else None,
            "sclk": active_clock(device / "pp_dpm_sclk"),
            "mclk": active_clock(device / "pp_dpm_mclk"),
        })
    return gpus


def csv_int(value: str) -> int | None:
    value = value.strip()
    if not value or value == "[Not Supported]":
        return None
    try:
        return int(value)
    except ValueError:
        return None


def csv_float(value: str) -> float | None:
    value = value.strip()
    if not value or value == "[Not Supported]":
        return None
    try:
        return float(value)
    except ValueError:
        return None


def mib_to_bytes(value: int | None) -> int | None:
    return value * 1024 * 1024 if value is not None else None


def collect_nvidia_gpus() -> list[dict[str, Any]]:
    output = run_command(
        [
            "nvidia-smi",
            "--query-gpu=name,utilization.gpu,utilization.memory,memory.used,memory.total,temperature.gpu,power.draw,clocks.sm,clocks.mem",
            "--format=csv,noheader,nounits",
        ]
    )
    gpus: list[dict[str, Any]] = []
    for index, line in enumerate(output.splitlines()):
        parts = [part.strip() for part in line.split(",")]
        if len(parts) != 9:
            continue
        memory_used = csv_int(parts[3])
        memory_total = csv_int(parts[4])
        sclk = csv_int(parts[7])
        mclk = csv_int(parts[8])
        gpus.append({
            "vendor": "NVIDIA",
            "name": parts[0],
            "index": index,
            "gpu_busy_percent": csv_int(parts[1]),
            "mem_busy_percent": csv_int(parts[2]),
            "vram_used": mib_to_bytes(memory_used),
            "vram_total": mib_to_bytes(memory_total),
            "temp_c": csv_float(parts[5]),
            "power_w": csv_float(parts[6]),
            "sclk": f"{sclk} MHz" if sclk is not None else None,
            "mclk": f"{mclk} MHz" if mclk is not None else None,
        })
    return gpus


def collect_gpu(drm_root: Path = DEFAULT_DRM_ROOT) -> dict[str, Any]:
    gpus = [*collect_amd_gpus(drm_root), *collect_nvidia_gpus()]
    if gpus:
        return {"gpus": gpus}
    return {"error": f"no AMD GPU found under {drm_root}"}


def run_command(args: list[str], timeout: float = 1.0) -> str:
    try:
        result = subprocess.run(
            args,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout,
        )
    except (OSError, subprocess.TimeoutExpired):
        return ""
    return result.stdout.strip()


def collect_llama_process() -> dict[str, str] | None:
    pgrep = run_command(["pgrep", "-f", "[l]lama-server"])
    pids = [pid for pid in pgrep.splitlines() if pid.strip()]
    if not pids:
        return None
    pid = pids[0]
    output = run_command(["ps", "-p", pid, "-o", "pid=,%cpu=,rss=,etime=,args="], timeout=1.0)
    if not output:
        return {"pid": pid, "cpu_percent": "n/a", "rss": "n/a", "etime": "n/a", "cmd": "n/a"}
    parts = output.split(None, 4)
    if len(parts) < 5:
        return {"pid": pid, "cpu_percent": "n/a", "rss": "n/a", "etime": "n/a", "cmd": output}
    rss_bytes = int(parts[2]) * 1024 if parts[2].isdigit() else None
    return {
        "pid": parts[0],
        "cpu_percent": parts[1],
        "rss": format_bytes(rss_bytes),
        "etime": parts[3],
        "cmd": parts[4],
    }


def http_json_or_text(url: str, timeout: float = 0.8, max_bytes: int = 4096) -> str:
    request = Request(url, headers={"Accept": "application/json"})
    try:
        with urlopen(request, timeout=timeout) as response:
            body = response.read(max_bytes).decode("utf-8", errors="replace").strip()
    except (OSError, URLError) as exc:
        return f"unreachable: {exc.__class__.__name__}"
    return body or "ok"


def parse_slots(body: str) -> list[dict[str, Any]]:
    try:
        raw_slots = json.loads(body)
    except json.JSONDecodeError:
        return []
    if not isinstance(raw_slots, list):
        return []
    slots: list[dict[str, Any]] = []
    for slot in raw_slots:
        if not isinstance(slot, dict):
            continue
        next_token = slot.get("next_token")
        decoded = 0
        if isinstance(next_token, list) and next_token and isinstance(next_token[0], dict):
            decoded = int(next_token[0].get("n_decoded") or 0)
        slots.append(
            {
                "id": int(slot.get("id") or 0),
                "task": int(slot.get("id_task") or 0),
                "is_processing": bool(slot.get("is_processing")),
                "decoded": decoded,
            }
        )
    return slots


class TpsTracker:
    def __init__(self) -> None:
        self.previous: dict[tuple[int, int], tuple[int, float]] = {}

    def update(self, slots: list[dict[str, Any]], now: float | None = None) -> dict[str, Any]:
        sample_time = time.monotonic() if now is None else now
        current: dict[tuple[int, int], tuple[int, float]] = {}
        live_tps = 0.0
        has_sample = False
        for slot in slots:
            key = (int(slot["id"]), int(slot["task"]))
            decoded = int(slot["decoded"])
            current[key] = (decoded, sample_time)
            if key in self.previous:
                previous_decoded, previous_time = self.previous[key]
                elapsed = sample_time - previous_time
                delta = decoded - previous_decoded
                if elapsed > 0 and delta >= 0:
                    live_tps += delta / elapsed
                    has_sample = True
        self.previous = current
        return {
            "live_tps": round(live_tps, 1) if has_sample else None,
            "active_slots": sum(1 for slot in slots if slot["is_processing"]),
            "total_slots": len(slots),
        }


def parse_last_eval_tps(lines: list[str]) -> float | None:
    # Pattern 1: "eval time = X tokens per second)" format (original llama.cpp)
    pattern1 = re.compile(r"^\s*eval time\s*=.*?([0-9]+(?:\.[0-9]+)?) tokens per second\)")
    # Pattern 2: "n_decoded = XXX, tg = XX.XX t/s" format (llama-speed.log)
    pattern2 = re.compile(r"n_decoded\s*=\s*([0-9]+)\s*,\s*tg\s*=\s*([0-9.]+)\s*t/s")
    
    for line in reversed(lines):
        # Try pattern 1 first
        match1 = pattern1.search(line)
        if match1:
            return float(match1.group(1))
        
        # Try pattern 2
        match2 = pattern2.search(line)
        if match2:
            n_decoded = int(match2.group(1))
            tg = float(match2.group(2))
            # TPS = n_decoded / tg (time in seconds)
            if tg > 0:
                return n_decoded / tg
    
    return None


def summarize_models(models_body: str) -> str:
    if models_body.startswith("unreachable:"):
        return models_body
    if '"id"' not in models_body:
        return models_body[:120]
    ids: list[str] = []
    marker = '"id"'
    rest = models_body
    while marker in rest and len(ids) < 3:
        rest = rest.split(marker, 1)[1]
        if ':' not in rest:
            break
        rest = rest.split(':', 1)[1].lstrip()
        if not rest.startswith('"'):
            continue
        rest = rest[1:]
        model_id, _, rest = rest.partition('"')
        if model_id:
            ids.append(model_id)
    return ", ".join(ids) if ids else models_body[:120]


def collect_api(base_url: str = DEFAULT_BASE_URL) -> dict[str, str]:
    health = http_json_or_text(f"{base_url}/health")
    models = summarize_models(http_json_or_text(f"{base_url}/v1/models"))
    return {"health": health, "models": models}


def collect_slots(base_url: str = DEFAULT_BASE_URL) -> list[dict[str, Any]] | None:
    body = http_json_or_text(f"{base_url}/slots", max_bytes=1024 * 1024)
    if body.startswith("unreachable:"):
        return None
    return parse_slots(body)


def summarize_iostat(row: str) -> str:
    parts = row.split()
    if len(parts) < 9:
        return row
    device = parts[0]
    reads = parts[1]
    read_kib = parts[2]
    writes = parts[7]
    write_kib = parts[8]
    util = parts[-1]
    return f"{device} r/s {reads} w/s {writes} read {read_kib} KiB/s write {write_kib} KiB/s util {util}%"


def summarize_vmstat(row: str) -> str:
    parts = row.split()
    if len(parts) < 17:
        return row
    return f"r {parts[0]} b {parts[1]} free {parts[3]} KiB in {parts[10]} cs {parts[11]} cpu {parts[12]}u/{parts[13]}s/{parts[14]}i"


def compact_free_row(row: str) -> str:
    return " ".join(row.split())


def parse_proc_stat(text: str) -> dict[str, list[int]]:
    samples: dict[str, list[int]] = {}
    for line in text.splitlines():
        parts = line.split()
        if not parts or not re.fullmatch(r"cpu\d+", parts[0]):
            continue
        try:
            samples[parts[0]] = [int(value) for value in parts[1:]]
        except ValueError:
            continue
    return samples


def read_proc_stat(path: Path = PROC_STAT) -> dict[str, list[int]]:
    text = read_text(path)
    return parse_proc_stat(text or "")


def cpu_percentages(before: dict[str, list[int]], after: dict[str, list[int]]) -> list[tuple[str, int]]:
    percentages: list[tuple[str, int]] = []
    for name in sorted(after, key=lambda value: int(value[3:])):
        if name not in before:
            continue
        old = before[name]
        new = after[name]
        if len(old) < 4 or len(new) < 4:
            continue
        total_delta = sum(new) - sum(old)
        idle_delta = (new[3] + (new[4] if len(new) > 4 else 0)) - (old[3] + (old[4] if len(old) > 4 else 0))
        if total_delta <= 0:
            percent = 0
        else:
            percent = int(round(((total_delta - idle_delta) / total_delta) * 100))
        percentages.append((name[3:], int(clamp(percent, 0, 100))))
    return percentages


def collect_cpu_cores() -> list[tuple[str, int]]:
    before = read_proc_stat()
    time.sleep(0.1)
    after = read_proc_stat()
    return cpu_percentages(before, after)


def collect_system() -> dict[str, str]:
    load = " ".join(f"{value:.2f}" for value in os.getloadavg())
    mem = run_command(["free", "-h"], timeout=1.0).splitlines()
    vmstat = run_command(["vmstat", "1", "2"], timeout=2.5).splitlines()
    iostat = run_command(["iostat", "-dx", "1", "1"], timeout=2.0).splitlines()
    return {
        "load": load,
        "mem": mem[1] if len(mem) > 1 else "n/a",
        "swap": mem[2] if len(mem) > 2 else "n/a",
        "vmstat": summarize_vmstat(vmstat[-1]) if vmstat else "n/a",
        "iostat": summarize_iostat(iostat[-1]) if iostat else "n/a",
        "cpu_cores": collect_cpu_cores(),
    }


def newest_log(llama_dir: Path = DEFAULT_LLAMA_DIR) -> Path | None:
    # Patterns to match for llama log files
    log_patterns = ["llama-*.log", "llama-speed.log"]
    
    # First, try the specified directory
    for pattern in log_patterns:
        logs = list(llama_dir.glob(pattern))
        if logs:
            if pattern == "llama-*.log":
                dated_logs = [path for path in logs if re.fullmatch(r"llama-[0-9-]+\.log", path.name)]
                if dated_logs:
                    return max(dated_logs, key=lambda path: path.name)
            return max(logs, key=lambda path: path.stat().st_mtime)
    
    # If no logs in specified dir, search in common directories
    for search_dir in LLAMA_LOG_SEARCH_PATHS:
        if search_dir == llama_dir:
            continue  # Already checked
        for pattern in log_patterns:
            logs = list(search_dir.glob(pattern))
            if logs:
                if pattern == "llama-*.log":
                    dated_logs = [path for path in logs if re.fullmatch(r"llama-[0-9-]+\.log", path.name)]
                    if dated_logs:
                        return max(dated_logs, key=lambda path: path.name)
                return max(logs, key=lambda path: path.stat().st_mtime)
    
    return None


def read_recent_logs(llama_dir: Path = DEFAULT_LLAMA_DIR, count: int = 8) -> list[str]:
    log = newest_log(llama_dir)
    if log is None:
        return [f"no llama-*.log files found in {llama_dir}"]
    try:
        lines = log.read_text(errors="replace").splitlines()
    except OSError as exc:
        return [f"failed to read {log}: {exc}"]
    if not lines:
        return [f"{log.name}: empty"]
    return [f"{log.name}: {line}" for line in lines[-count:]]


def read_last_eval_tps(llama_dir: Path = DEFAULT_LLAMA_DIR) -> float | None:
    log = newest_log(llama_dir)
    if log is None:
        return None
    try:
        lines = log.read_text(errors="replace").splitlines()
    except OSError:
        return None
    return parse_last_eval_tps(lines)


def collect_tps(base_url: str, llama_dir: Path, tracker: TpsTracker | None) -> dict[str, Any]:
    slots = collect_slots(base_url)
    if slots is None:
        slot_stats = {"live_tps": None, "active_slots": "n/a", "total_slots": "n/a"}
    else:
        slot_stats = tracker.update(slots) if tracker is not None else TpsTracker().update(slots)
    slot_stats["last_eval_tps"] = read_last_eval_tps(llama_dir)
    return slot_stats


def collect_snapshot(
    drm_root: Path = DEFAULT_DRM_ROOT,
    llama_dir: Path = DEFAULT_LLAMA_DIR,
    base_url: str = DEFAULT_BASE_URL,
    tps_tracker: TpsTracker | None = None,
) -> dict[str, Any]:
    return {
        "hostname": socket.gethostname(),
        "time": time.strftime("%H:%M:%S"),
        "gpu": collect_gpu(drm_root),
        "llama": collect_llama_process(),
        "tps": collect_tps(base_url, llama_dir, tps_tracker),
        "api": collect_api(base_url),
        "system": collect_system(),
        "logs": read_recent_logs(llama_dir),
    }


def pct_text(value: int | float | None) -> str:
    return "n/a" if value is None else f"{value}%"


def tps_text(value: int | float | None) -> str:
    return "n/a" if value is None else f"{float(value):.1f}"


def single_line(text: str, width: int) -> str:
    clean = text.replace("\n", " ")
    if len(clean) <= width:
        return clean
    return clean[: max(0, width - 1)] + "…"


def line_style(line: str) -> str:
    stripped = line.strip()
    lower = stripped.lower()
    if line.startswith("lltop "):
        return "header"
    if line.startswith("+-- "):
        return "panel"
    if any(word in lower for word in ("unreachable", "error", "failed")):
        return "bad"
    if lower.startswith("health:") or lower.startswith("models:"):
        return "good"
    percent_values = [int(match) for match in re.findall(r"(\d+)%", line)]
    if percent_values:
        return meter_style(max(percent_values))
    if stripped.startswith("./") or stripped.startswith("llama-"):
        return "muted"
    return "normal"


def style_palette() -> dict[str, dict[str, Any]]:
    return {
        "header": {"foreground": "black", "background": "cyan", "bold": True, "dim": False},
        "panel": {"foreground": "magenta", "background": "default", "bold": True, "dim": False},
        "good": {"foreground": "green", "background": "default", "bold": True, "dim": False},
        "warn": {"foreground": "yellow", "background": "default", "bold": True, "dim": False},
        "bad": {"foreground": "red", "background": "default", "bold": True, "dim": False},
        "muted": {"foreground": "cyan", "background": "default", "bold": False, "dim": False},
        "normal": {"foreground": "white", "background": "default", "bold": False, "dim": False},
    }


def init_colors() -> None:
    if not curses.has_colors():
        return
    curses.start_color()
    try:
        curses.use_default_colors()
        background = -1
    except curses.error:
        background = curses.COLOR_BLACK
    color_numbers = {
        "black": curses.COLOR_BLACK,
        "blue": curses.COLOR_BLUE,
        "cyan": curses.COLOR_CYAN,
        "green": curses.COLOR_GREEN,
        "magenta": curses.COLOR_MAGENTA,
        "red": curses.COLOR_RED,
        "white": curses.COLOR_WHITE,
        "yellow": curses.COLOR_YELLOW,
    }
    for pair_number, style in enumerate(style_palette().values(), start=1):
        foreground = color_numbers[style["foreground"]]
        pair_background = background if style["background"] == "default" else color_numbers[style["background"]]
        try:
            curses.init_pair(pair_number, foreground, pair_background)
        except curses.error:
            pass


def style_attr(style: str) -> int:
    if not curses.has_colors():
        return 0
    pair_numbers = {
        "header": 1,
        "panel": 2,
        "good": 3,
        "warn": 4,
        "bad": 5,
        "muted": 6,
        "normal": 7,
    }
    attr = curses.color_pair(pair_numbers.get(style, 7))
    palette = style_palette().get(style, style_palette()["normal"])
    if palette["bold"]:
        attr |= curses.A_BOLD
    if palette["dim"]:
        attr |= curses.A_DIM
    return attr


def render_cpu_cores(cores: list[tuple[str, int]], per_row: int = 4) -> list[str]:
    if not cores:
        return []
    lines = ["  CPU cores:"]
    row: list[str] = []
    for core, percent in cores:
        row.append(f"{int(core):02d} {bar(percent, 10)} {percent}%")
        if len(row) == per_row:
            lines.append("  " + "  ".join(row))
            row = []
    if row:
        lines.append("  " + "  ".join(row))
    return lines


def system_memory_io_lines(system: dict[str, Any]) -> list[str]:
    lines: list[str] = []
    for key in ("mem", "swap", "vmstat", "iostat"):
        value = system.get(key)
        if not value or value == "n/a":
            continue
        if key == "mem":
            lines.append("  Memory columns: total used free shared buff/cache available")
        if key == "swap":
            lines.append("  Swap columns: total used free")
        prefix = "  " if key in ("mem", "swap") else f"  {key}: "
        if key in ("mem", "swap"):
            value = compact_free_row(value)
        lines.append(f"{prefix}{value}")
    return lines


def system_stacked_lines(system: dict[str, Any]) -> list[str]:
    lines = [f"  load: {system.get('load', 'n/a')}"]
    lines.extend(render_cpu_cores(system.get("cpu_cores") or []))
    lines.extend(system_memory_io_lines(system))
    return lines


def system_side_by_side_lines(system: dict[str, Any], width: int) -> list[str]:
    gap = "   "
    left_width = min(64, max(50, (width - len(gap)) // 2))
    right_width = max(40, width - left_width - len(gap))
    cpu_block = section("CPU", [f"  load: {system.get('load', 'n/a')}", *render_cpu_cores(system.get("cpu_cores") or [], per_row=2)], left_width)[:-1]
    memory_block = section("Memory / IO", system_memory_io_lines(system), right_width)[:-1]
    return join_columns(cpu_block, memory_block, left_width, gap)


def render_snapshot(snapshot: dict[str, Any], width: int | None = None, height: int | None = None) -> str:
    width = width or shutil.get_terminal_size((100, 30)).columns
    height = height or shutil.get_terminal_size((100, 30)).lines
    gpu = snapshot.get("gpu") or {}
    llama = snapshot.get("llama")
    api = snapshot.get("api") or {}
    system = snapshot.get("system") or {}
    tps = snapshot.get("tps") or {}
    logs = snapshot.get("logs") or []

    lines = [f"lltop {snapshot.get('hostname', 'unknown')} {snapshot.get('time', '')}  q quit  r refresh"]

    if "error" in gpu:
        lines.extend(section("GPU", [f"  {gpu['error']}"], width))
    else:
        gpu_lines: list[str] = []
        for index, device in enumerate(gpu.get("gpus") or []):
            gpu_busy = device.get("gpu_busy_percent")
            mem_busy = device.get("mem_busy_percent")
            vram_used = device.get("vram_used")
            vram_total = device.get("vram_total")
            temp = device.get("temp_c")
            power = device.get("power_w")
            label = f"{device.get('vendor', 'GPU')} {device.get('name', index)}"
            location = device.get("path") or f"index {device.get('index', index)}"
            if gpu_lines:
                gpu_lines.append("")
            gpu_lines.extend([
                f"  {label} ({location})",
                f"  Core {pct_text(gpu_busy):>5} {bar(gpu_busy)}   Mem busy {pct_text(mem_busy):>5} {bar(mem_busy)}",
                f"  VRAM {format_bytes(vram_used)} / {format_bytes(vram_total)}   Temp {temp:.1f} C" if temp is not None else f"  VRAM {format_bytes(vram_used)} / {format_bytes(vram_total)}   Temp n/a",
                f"  Power {power:.1f} W   SCLK {device.get('sclk') or 'n/a'}   MCLK {device.get('mclk') or 'n/a'}" if power is not None else f"  Power n/a   SCLK {device.get('sclk') or 'n/a'}   MCLK {device.get('mclk') or 'n/a'}",
            ])
        lines.extend(
            section(
                "GPU",
                gpu_lines or ["  no GPU metrics found"],
                width,
            )
        )

    llama_lines: list[str]
    if llama:
        llama_lines = [
            f"  PID {llama.get('pid', 'n/a')}   CPU {llama.get('cpu_percent', 'n/a')}%   RSS {llama.get('rss', 'n/a')}   Runtime {llama.get('etime', 'n/a')}",
            f"  tokens/sec: live {tps_text(tps.get('live_tps'))}   active slots {tps.get('active_slots', 'n/a')}/{tps.get('total_slots', 'n/a')}   last eval {tps_text(tps.get('last_eval_tps'))}",
            f"  {llama.get('cmd', 'n/a')}",
        ]
    else:
        llama_lines = ["  no llama-server process found"]
    lines.extend(section("llama.cpp", llama_lines, width))

    lines.extend(section("API", [f"  health: {api.get('health', 'n/a')}", f"  models: {api.get('models', 'n/a')}"], width))
    system_lines = system_side_by_side_lines(system, width) if width >= 120 else system_stacked_lines(system)
    lines.extend(section("System", system_lines, width))
    log_section = section("Recent log", [f"  {line}" for line in logs], width)
    min_log_lines = min(len(log_section), 4)
    if len(lines) + min_log_lines > height:
        lines = lines[: max(0, height - min_log_lines)]
    available_log_lines = max(0, height - len(lines))
    if available_log_lines and len(log_section) > available_log_lines:
        log_section = [log_section[0], *log_section[-(available_log_lines - 1) :]]
    lines.extend(log_section)

    return "\n".join(single_line(line, width) for line in lines[:height])


def draw(stdscr: Any, args: argparse.Namespace) -> None:
    curses.curs_set(0)
    init_colors()
    stdscr.nodelay(True)
    stdscr.timeout(250)
    tps_tracker = TpsTracker()
    last_refresh = 0.0
    output = ""
    while True:
        now = time.monotonic()
        if now - last_refresh >= args.interval or not output:
            snapshot = collect_snapshot(args.drm_root, args.llama_dir, args.base_url, tps_tracker)
            height, width = stdscr.getmaxyx()
            output = render_snapshot(snapshot, width=width, height=height)
            stdscr.erase()
            for row, line in enumerate(output.splitlines()[:height]):
                try:
                    stdscr.addstr(row, 0, line[: max(0, width - 1)], style_attr(line_style(line)))
                except curses.error:
                    pass
            stdscr.refresh()
            last_refresh = now
        key = stdscr.getch()
        if key in (ord("q"), ord("Q")):
            break
        if key in (ord("r"), ord("R")):
            last_refresh = 0.0


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Monitor llama.cpp and AMD GPU usage")
    parser.add_argument("--once", action="store_true", help="print one dashboard snapshot and exit")
    parser.add_argument("--interval", type=float, default=1.0, help="refresh interval in seconds")
    parser.add_argument("--drm-root", type=Path, default=DEFAULT_DRM_ROOT, help="DRM sysfs root")
    parser.add_argument("--llama-dir", type=Path, default=DEFAULT_LLAMA_DIR, help="llama.cpp directory containing llama-*.log")
    parser.add_argument("--base-url", default=DEFAULT_BASE_URL, help="llama.cpp server base URL")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    if args.once:
        print(render_snapshot(collect_snapshot(args.drm_root, args.llama_dir, args.base_url, TpsTracker())))
        return 0
    curses.wrapper(draw, args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
